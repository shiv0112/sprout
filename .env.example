# ── LLM providers ────────────────────────────────────────────────────────────
# Planning + agent execution use NVIDIA NIM as PRIMARY and Mistral as FALLBACK
# (both OpenAI-compatible). Provide either or both; a provider is used only if
# its key is set.
NVIDIA_API_KEY=your_nvidia_api_key      # primary — NVIDIA NIM
MISTRAL_API_KEY=your_mistral_api_key    # fallback — also used by synthesis (Codestral)

# Optional overrides (defaults shown):
# SPROUT_LLM_PRIMARY=nim                   # "nim" or "mistral"
# SPROUT_NIM_MODEL=z-ai/glm-5.2            # NVIDIA NIM model (must support tool-calling)
# SPROUT_MISTRAL_MODEL=mistral-large-latest

# Clerk auth (get from https://dashboard.clerk.com)
CLERK_DOMAIN=your-app.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key

# Service-to-service auth (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SPROUT_INTERNAL_SECRET=your_internal_secret

# Browser clients allowed to call local APIs directly (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://localhost:5173,http://localhost:5174
