# Mistral API key for planning (chat_backend)
MISTRAL_API_KEY=your_mistral_api_key

# NVIDIA NIM API key for synthesis (OpenCode + NIM)
NVIDIA_API_KEY=your_nvidia_api_key

# Clerk auth (get from https://dashboard.clerk.com)
CLERK_DOMAIN=your-app.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key

# Service-to-service auth (generate with: python -c "import secrets; print(secrets.token_hex(32))")
KILN_INTERNAL_SECRET=your_internal_secret

# Browser clients allowed to call local APIs directly (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://localhost:5173,http://localhost:5174
