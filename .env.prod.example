# ─────────────────────────────────────────────────────────────────────────────
# Sprout — droplet BACKEND environment (frontend runs on Vercel).
#
#   cp .env.prod.example .env.prod   then fill in, then ./deploy.sh
#
# Read by docker-compose.prod.yml and deploy.sh.
# NEVER commit .env.prod — it holds secrets (it is git-ignored).
# ─────────────────────────────────────────────────────────────────────────────

# ── This droplet's public address ────────────────────────────────────────────
# The backend MUST be HTTPS (the Vercel frontend is HTTPS and browsers block
# http calls from an https page). So SITE_ADDRESS must be a HOSTNAME that Caddy
# can get a certificate for — a real domain, or a free sslip.io name for a bare
# IP (e.g. droplet 203.0.113.10 → api.203-0-113-10.sslip.io).
#
#   SITE_ADDRESS     = the hostname Caddy serves + gets a cert for
#   PUBLIC_BASE_URL  = https:// + that hostname (used as the MCP OAuth issuer)
SITE_ADDRESS=api.sprout.168-144-130-174.sslip.io
PUBLIC_BASE_URL=https://api.sprout.168-144-130-174.sslip.io

# ── Who may call this backend ────────────────────────────────────────────────
# CORS_ORIGINS is the RESTRICTION that locks the API to your Vercel frontend:
# only these browser origins may call it cross-origin. Set it to your Vercel
# URL(s), comma-separated (include any preview/custom domains you use).
CORS_ORIGINS=https://your-app.vercel.app
# Shown in links/UI copy from the backend:
SPROUT_UI_URL=https://your-app.vercel.app

# ── Datastore ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_to_a_strong_password

# ── Service-to-service auth (internal secret for inter-service calls) ─────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SPROUT_INTERNAL_SECRET=change_me

# ── LLM providers — Groq everywhere ──────────────────────────────────────────
# Reasoning model (gpt-oss-120b) for real tasks; fast non-thinking model
# (llama-3.3-70b-versatile) for small ones. Mistral/NVIDIA are optional fallbacks.
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL_REASONING=openai/gpt-oss-120b
GROQ_MODEL_FAST=llama-3.3-70b-versatile
SPROUT_LLM_PRIMARY=groq
# Tool synthesis (OpenCode) runs on Groq's reasoning model:
SPROUT_SYNTHESIS_OPENCODE_MODEL=groq/openai/gpt-oss-120b
MISTRAL_API_KEY=your_mistral_api_key    # optional fallback
NVIDIA_API_KEY=your_nvidia_api_key      # optional fallback

# ── Clerk (backend verifies the Clerk JWT the frontend sends) ────────────────
CLERK_DOMAIN=your-app.clerk.accounts.dev
CLERK_SECRET_KEY=sk_live_your_secret_key

# ── MCP ──────────────────────────────────────────────────────────────────────
# You are on HTTPS, so the OAuth issuer is https — no need to allow http.
SPROUT_MCP_ALLOW_HTTP_ISSUER=false
