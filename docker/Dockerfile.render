# ─────────────────────────────────────────────────────────────────────────────
# Sprout — single-container BACKEND image for Render.
#
# Runs ALL Python microservices in one container behind a Caddy reverse proxy:
#
#   Render $PORT ──► Caddy ──┬─ /registry/*  ─► 127.0.0.1:8766  registry_api
#                            ├─ /chat/*      ─► 127.0.0.1:8765  chat_backend
#                            ├─ /synthesis/* ─► 127.0.0.1:8002  synthesis_service
#                            ├─ /mcp/*       ─► 127.0.0.1:8768  mcp_server
#                            ├─ /executor/*  ─► 127.0.0.1:8767  tool_executor
#                            └─ /health      ─► 200 (Render health check)
#
# Processes are supervised by supervisord (see docker/render/supervisord.conf).
# The frontend (registry_ui) deploys separately to Vercel.
#
# Build locally:
#   docker build -f docker/Dockerfile.render -t sprout-backend .
#   docker run --rm -p 8080:8080 -e PORT=8080 --env-file .env sprout-backend
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 1: install all workspace Python deps into one venv ─────────────────
FROM python:3.12-slim AS builder

RUN pip install --no-cache-dir uv
WORKDIR /app

# Dependency manifests first for a cached layer.
COPY pyproject.toml uv.lock ./
COPY packages/shared/pyproject.toml packages/shared/pyproject.toml
COPY packages/shared/README.md packages/shared/LICENSE packages/shared/
COPY packages/registry_api/pyproject.toml packages/registry_api/pyproject.toml
COPY packages/registry_api/README.md packages/registry_api/LICENSE packages/registry_api/
COPY packages/chat_backend/pyproject.toml packages/chat_backend/pyproject.toml
COPY packages/synthesis_service/pyproject.toml packages/synthesis_service/pyproject.toml
COPY packages/tool_executor/pyproject.toml packages/tool_executor/pyproject.toml
COPY packages/mcp_server/pyproject.toml packages/mcp_server/pyproject.toml

# Stub package modules so the editable workspace build resolves before the
# real source is copied. py.typed is required by sprout-shared's PEP 561 marker.
RUN mkdir -p packages/shared/sprout_shared \
    packages/registry_api/sprout_registry \
    packages/chat_backend/sprout_chat_backend \
    packages/mcp_server/sprout_mcp \
    packages/tool_executor/sprout_executor \
    packages/synthesis_service/sprout_synthesis && \
    touch packages/shared/sprout_shared/__init__.py \
    packages/shared/sprout_shared/py.typed \
    packages/registry_api/sprout_registry/__init__.py \
    packages/chat_backend/sprout_chat_backend/__init__.py \
    packages/mcp_server/sprout_mcp/__init__.py \
    packages/tool_executor/sprout_executor/__init__.py \
    packages/synthesis_service/sprout_synthesis/__init__.py

# Install the whole workspace (all 5 services + shared) into /app/.venv.
# pyyaml (needed by synthesis) is already a dep of shared/registry_api/chat_backend.
RUN uv sync --no-dev --frozen 2>/dev/null || uv sync --no-dev

# ── Stage 2: runtime — Python venv + Node/OpenCode + Caddy + supervisord ─────
FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/app/.venv/bin:$PATH"

# System deps: curl (healthchecks), gnupg (repo keys), supervisor (process mgr).
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl ca-certificates gnupg supervisor debian-keyring debian-archive-keyring apt-transport-https && \
    rm -rf /var/lib/apt/lists/*

# Node.js 22 LTS — required by the synthesis service's OpenCode CLI.
RUN mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" > /etc/apt/sources.list.d/nodesource.list && \
    apt-get update && apt-get install -y --no-install-recommends nodejs && \
    npm install -g opencode-ai @ai-sdk/openai-compatible && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Caddy reverse proxy (official repo).
RUN curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg && \
    curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' > /etc/apt/sources.list.d/caddy-stable.list && \
    apt-get update && apt-get install -y --no-install-recommends caddy && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Python venv from the builder.
COPY --from=builder /app/.venv /app/.venv

# All service source (editable installs point at these paths) + registry tools.
COPY packages/shared/         packages/shared/
COPY packages/registry_api/   packages/registry_api/
COPY packages/chat_backend/   packages/chat_backend/
COPY packages/synthesis_service/ packages/synthesis_service/
COPY packages/tool_executor/  packages/tool_executor/
COPY packages/mcp_server/     packages/mcp_server/
COPY registry/                registry/

# OpenCode config for the synthesis CLI.
RUN mkdir -p /root/.config/opencode /app/logs /tmp/opencode_workspace
COPY packages/synthesis_service/opencode.json /root/.config/opencode/opencode.json

# Process supervision + reverse-proxy config.
COPY docker/render/supervisord.conf /etc/supervisord.conf
COPY docker/render/Caddyfile /etc/caddy/Caddyfile

# Render injects $PORT; Caddy reads it (defaults to 8080 for local runs).
ENV PORT=8080
EXPOSE 8080

# Render health check hits Caddy's /health (see render.yaml healthCheckPath).
CMD ["supervisord", "-c", "/etc/supervisord.conf"]
