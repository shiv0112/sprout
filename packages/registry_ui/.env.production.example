# ─────────────────────────────────────────────────────────────────────────────
# registry_ui — Vercel production environment.
#
# Set these in Vercel ▸ Project ▸ Settings ▸ Environment Variables (Production).
# Replace <render-host> with your Render backend host, e.g.
#   sprout-backend.onrender.com
#
# The NEXT_PUBLIC_* values are baked into the browser bundle AT BUILD TIME, so
# they must be present before Vercel builds. They must include the path prefix
# that the Caddy proxy on the backend routes on (/registry, /chat, ...).
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend service URLs (client-side — baked into the bundle) ──
NEXT_PUBLIC_REGISTRY_URL=https://<render-host>/registry
NEXT_PUBLIC_CHAT_BACKEND=https://<render-host>/chat
NEXT_PUBLIC_SYNTHESIS_SERVICE_URL=https://<render-host>/synthesis
NEXT_PUBLIC_MCP_SERVER_URL=https://<render-host>/mcp
NEXT_PUBLIC_TOOL_EXECUTOR_URL=https://<render-host>/executor

# ── Server-side URLs (used by /api/* route handlers on Vercel) ──
# Vercel has no private network to Render, so point these at the same public
# URLs. If omitted, the code falls back to the NEXT_PUBLIC_* values above.
REGISTRY_API_INTERNAL=https://<render-host>/registry
CHAT_BACKEND_INTERNAL=https://<render-host>/chat

# ── Clerk auth ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_key
CLERK_SECRET_KEY=sk_live_your_secret_key
